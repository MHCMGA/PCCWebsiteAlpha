# Resend (https://resend.com) — set these in Vercel Project Settings → Environment Variables
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
RESEND_TO_EMAIL=you@yourdomain.com

# Sender address. Until you verify a domain in Resend, you can use onboarding@resend.dev.
# After verifying your domain (e.g. palmettoconsultingsc.com), use something like contact@palmettoconsultingsc.com.
RESEND_FROM_EMAIL=onboarding@resend.dev
