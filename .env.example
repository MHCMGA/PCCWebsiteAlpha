# Resend (https://resend.com) — set these in Vercel Project Settings → Environment Variables
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
RESEND_TO_EMAIL=you@yourdomain.com

# Sender address. Until you verify a domain in Resend, you can use onboarding@resend.dev.
# After verifying your domain (e.g. palmettoconsultingsc.com), use something like contact@palmettoconsultingsc.com.
RESEND_FROM_EMAIL=onboarding@resend.dev

# Microsoft Clarity (https://clarity.microsoft.com) — session replays + heatmaps.
# Create a project, copy the Project ID from Settings → Setup. Leaving this
# unset disables Clarity (the script never loads).
VITE_CLARITY_PROJECT_ID=

# LinkedIn Insight Tag — visitor company / job-title visibility.
# Get the Partner ID from LinkedIn Campaign Manager → Account Assets → Insight
# Tag. A free Campaign Manager account is sufficient (no ad spend required).
# Leaving this unset disables the tag (the script never loads).
VITE_LINKEDIN_PARTNER_ID=

# RB2B (https://rb2b.com) — US-only person-level visitor de-anonymization.
# Sign up, then copy the Team ID from your install snippet (the long hex/uuid
# string in the script src). Leaving this unset disables RB2B.
VITE_RB2B_TEAM_ID=

# Search-console / SEO-tool ownership verification metas. When you go through
# the verification flow for each tool, choose the "HTML tag" method, copy ONLY
# the value of the content="..." attribute (not the whole tag), and paste it
# below.
#
# Google Search Console:    https://search.google.com/search-console
# Bing Webmaster Tools:     https://www.bing.com/webmasters  (also imports from GSC)
# Ahrefs Webmaster Tools:   https://ahrefs.com/webmaster-tools
VITE_GOOGLE_SITE_VERIFICATION=
VITE_BING_SITE_VERIFICATION=
VITE_AHREFS_SITE_VERIFICATION=

# Sentry (https://sentry.io) — error tracking for both browser and server.
# Both DSNs come from the same Sentry project. The browser one is exposed to
# clients (safe — DSNs are public-by-design); the server one stays server-only.
# Leaving these unset disables Sentry entirely (init becomes a no-op).
VITE_SENTRY_DSN=
SENTRY_DSN=
# Build-time only: source-map upload so production stack traces symbolicate.
# Generate at https://sentry.io/settings/account/api/auth-tokens/ with the
# project:releases scope. Leaving SENTRY_AUTH_TOKEN unset skips the upload
# without breaking the build.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
