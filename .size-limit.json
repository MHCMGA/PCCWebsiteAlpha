[
  {
    "name": "Total initial JS (gzip)",
    "path": "dist/assets/*.js",
    "limit": "170 KB",
    "gzip": true
  },
  {
    "name": "React vendor chunk (gzip)",
    "path": "dist/assets/react-vendor-*.js",
    "limit": "75 KB",
    "gzip": true
  },
  {
    "name": "App index chunk (gzip)",
    "path": "dist/assets/index-*.js",
    "limit": "70 KB",
    "gzip": true
  },
  {
    "name": "CSS (gzip)",
    "path": "dist/assets/index-*.css",
    "limit": "10 KB",
    "gzip": true
  }
]
