{
  "name": "newwebsite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/encode-avif.mjs && vite build && node scripts/prerender.mjs && node scripts/generate-sitemap.mjs",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:md": "mado check .",
    "typecheck": "biome check .",
    "biome": "biome check .",
    "biome:fix": "biome check --write .",
    "biome:lint": "biome lint .",
    "preview": "node scripts/preview.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots",
    "knip": "knip",
    "knip:fix": "knip --fix --allow-remove-files",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "format": "oxfmt src scripts api",
    "format:check": "oxfmt --check src scripts api",
    "lighthouse": "npx --yes @lhci/cli@latest autorun --config=./lighthouserc.cjs",
    "sbom": "mkdir -p reports/sbom && syft scan dir:. --config .syft.yaml",
    "scan": "mkdir -p reports/scan && grype dir:. --config .grype.yaml -o table | tee reports/scan/grype.txt",
    "audit:all": "npm run sbom && npm run scan && npm run test:e2e && npm run lighthouse",
    "prerender": "node scripts/prerender.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "avif": "node scripts/encode-avif.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/render": "^2.0.8",
    "@sentry/node": "^10.53.1",
    "@sentry/react": "^10.53.1",
    "@sentry/vite-plugin": "^5.3.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.5.1",
    "@vercel/og": "^0.11.1",
    "@vercel/speed-insights": "^2.0.0",
    "botid": "^1.5.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^7.15.1",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "@sparticuz/chromium": "^148.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.6",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "knip": "^6.13.1",
    "oxfmt": "^0.49.0",
    "puppeteer-core": "^24.43.1",
    "sharp": "^0.34.5",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "sharp"
    ],
    "overrides": {
      "lodash": "^4.18.0",
      "ip-address": "^10.1.1",
      "tmp": "^0.2.4"
    }
  }
}
